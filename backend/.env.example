# Copy this file to .env and fill in real values. Never commit the real .env.

# Supabase project settings (Project Settings -> API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never exposed to the frontend

# Allowed frontend origin(s) for CORS, comma separated
ALLOWED_ORIGINS=http://localhost:5173,https://golden-hour.vercel.app

# Optional: enables LLM paraphrasing of question text/options so repeat
# questions don't look identical across students. Leave blank to skip
# paraphrasing entirely — the platform works fine without it.
ANTHROPIC_API_KEY=

# How long (seconds) a disconnected student has to reconnect before
# their session is marked expired instead of being treated as a violation.
RECONNECT_GRACE_SECONDS=90
